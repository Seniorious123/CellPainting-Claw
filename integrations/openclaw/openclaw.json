{
  "gateway": {
    "mode": "local",
    "port": 18789
  },
  "logging": {
    "level": "info"
  },
  "env": {
    "shellEnv": {
      "enabled": true,
      "timeoutMs": 15000
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/root/pipeline/CellPainting-Claw/integrations/openclaw/workspace",
      "repoRoot": "/root/pipeline/CellPainting-Claw",
      "skipBootstrap": true,
      "heartbeat": {
        "every": "0m"
      }
    }
  }
}
